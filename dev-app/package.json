{
  "name": "@wvdsh/dev-app",
  "version": "0.1.0",
  "private": true,
  "description": "Wavedash Dev — Electron host that powers `wavedash dev`. Downloaded by the CLI on first run; not a standalone app.",
  "productName": "Wavedash Dev",
  "main": "dist/main.js",
  "scripts": {
    "build": "bun build src/main.ts --target=node --format=cjs --outdir=dist --external=electron --sourcemap=external",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/patch-electron-name.mjs",
    "start": "bun run build && electron .",
    "dist": "bun run build && electron-builder",
    "dist:mac-arm64": "bun run build && electron-builder --mac --arm64",
    "dist:linux-x64": "bun run build && electron-builder --linux --x64",
    "dist:win-x64": "bun run build && electron-builder --win --x64"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.19.17",
    "electron": "^40.9.3",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "mime-types": "^2.1.35",
    "selfsigned": "^2.4.1"
  }
}
